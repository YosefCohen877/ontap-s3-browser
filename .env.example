# ══════════════════════════════════════════════════════════════════════════════
# .env.example — ontap-s3-browser configuration
# Copy this to .env and fill in your values before running.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── ONTAP S3 Credentials ──────────────────────────────────────────────────────
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Region — ONTAP usually ignores this but boto3 requires it.
# Use the region configured in your ONTAP SVM S3 service, or leave as us-east-1.
S3_REGION=us-east-1

# Full URL of your ONTAP S3 endpoint (no trailing slash).
# 
# ── RESTRICTED BUCKET MODE (NEW) ──────────────────────────────────────────
# Include a bucket name at the end of the URL to lock the browser to that bucket.
# This will:
#   1. Hide the full bucket list.
#   2. Jump straight to the bucket content on login.
#   3. Deny access to any other bucket (403 Forbidden).
# Example: https://ontap-s3/my-special-bucket
#
# ── STANDARD MODE ──────────────────────────────────────────────────────────
# Leave the path empty to show a grid of all cubes/buckets.
# Example: https://ontap-s3
# ───────────────────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=https://ontap-s3


# ── TLS / Certificate Configuration ──────────────────────────────────────────

# For custom CA certificates (self-signed or internal CAs):
#   1. Place your .crt or .pem files in the ./certs/ directory
#   2. Uncomment the COPY and RUN lines in Dockerfile
#   3. Rebuild: docker compose up --build
#   4. Leave S3_CA_BUNDLE empty (will use OS trust store automatically)
#
# Path to a custom CA bundle PEM file INSIDE the container (optional).
# Leave empty to use the OS trust store (recommended).
S3_CA_BUNDLE=

# Set to false ONLY for temporary debugging in isolated environments.
# This disables TLS certificate verification entirely — NEVER use in production.
S3_VERIFY_SSL=true


# ── ONTAP S3 Compatibility Settings ──────────────────────────────────────────

# Must be "path" for ONTAP S3. Virtual-style addressing will break.
S3_ADDRESSING_STYLE=path

# Conservative pool size — ONTAP S3 can hit TLS handshake limits under load.
S3_MAX_POOL_CONNECTIONS=5

# Timeout in seconds for initial TCP connection
S3_CONNECT_TIMEOUT=10

# Timeout in seconds waiting for response data
S3_READ_TIMEOUT=30


# ── Application Server ────────────────────────────────────────────────────────
APP_PORT=8080
LOG_LEVEL=INFO


# ── Web UI Authentication ─────────────────────────────────────────────────────
# These credentials protect the web interface.
# Use a strong password. These are server-side only — never sent to the browser.
WEB_USERNAME=admin
WEB_PASSWORD=change-me-please


# ── Feature Flags ─────────────────────────────────────────────────────────────
# Read-only mode by default. Set to true to enable write operations like delete and upload to buckets.
ENABLE_UPLOAD=true
ENABLE_DELETE=false
ENABLE_CREATE_BUCKET=false

# Permanently delete entire buckets from the UI. Empty buckets only unless the user checks
# "delete all objects" in the dialog (uses ListObjectVersions or ListObjectsV2 + DeleteObjects).
# Separate from per-object ENABLE_DELETE.
ENABLE_DELETE_BUCKET=false

# Show file count per bucket on the home page. Counts every object via pagination,
# which can be slow on large buckets. Set to false to disable.
ENABLE_BUCKET_COUNT=true

# Allow add/edit/delete of S3 bucket lifecycle rules (expiration policies).
# When false (default) the lifecycle panel opens in read-only mode.
#
# ── ONTAP version compatibility ─────────────────────────────────────────────
#   ONTAP 9.8 – 9.12.1  → No lifecycle support at all (UI shows a banner).
#   ONTAP 9.13.1+       → Full CRUD via the S3 API (expiration actions only).
#   ONTAP 9.14.1+       → Also manageable via ONTAP System Manager.
# Storage-class transitions (STANDARD_IA / GLACIER / DEEP_ARCHIVE) are NOT
# supported by ONTAP at any version and are intentionally omitted from the UI.
ENABLE_BUCKET_LIFECYCLE=false